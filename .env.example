# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# API-Ninjas: For Income Tax calculations
VITE_API_NINJAS_KEY="MY_API_NINJAS_KEY"

# Adzuna: For live job market tracking
VITE_ADZUNA_APP_ID="MY_ADZUNA_APP_ID"
VITE_ADZUNA_APP_KEY="MY_ADZUNA_APP_KEY"

# FRED (St. Louis Fed): For inflation and economic data
VITE_FRED_API_KEY="MY_FRED_API_KEY"
